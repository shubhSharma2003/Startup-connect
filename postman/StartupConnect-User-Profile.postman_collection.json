{
  "info": {
    "name": "StartupConnect - User Profile Management",
    "description": "User profile, skills, search, and S3-backed upload endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Get My Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users", "me"]
        }
      }
    },
    {
      "name": "Get User Profile By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users", "1"]
        }
      }
    },
    {
      "name": "Update My Profile",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Shubh Sharma\",\n  \"bio\": \"Java backend developer building student collaboration tools.\",\n  \"college\": \"Startup College\",\n  \"course\": \"Computer Science\",\n  \"graduationYear\": 2027,\n  \"githubUrl\": \"https://github.com/shubh\",\n  \"linkedinUrl\": \"https://linkedin.com/in/shubh\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users", "me"]
        }
      }
    },
    {
      "name": "Upload Profile Picture",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me/profile-picture",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users", "me", "profile-picture"]
        }
      }
    },
    {
      "name": "Upload Resume",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me/resume",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users", "me", "resume"]
        }
      }
    },
    {
      "name": "Add Skill",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Java\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me/skills",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users", "me", "skills"]
        }
      }
    },
    {
      "name": "Remove Skill",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me/skills/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users", "me", "skills", "1"]
        }
      }
    },
    {
      "name": "Search Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users?keyword=java&skill=Java&page=0&size=10&sort=name,asc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users"],
          "query": [
            {
              "key": "keyword",
              "value": "java"
            },
            {
              "key": "college",
              "value": "",
              "disabled": true
            },
            {
              "key": "course",
              "value": "",
              "disabled": true
            },
            {
              "key": "skill",
              "value": "Java"
            },
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "10"
            },
            {
              "key": "sort",
              "value": "name,asc"
            }
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ]
}
